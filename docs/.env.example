# Netlify Email Integration (Mailgun)
# Copy this file to .env and fill in values for local development.
# These same vars (except NETLIFY_EMAILS_DIRECTORY) must also be set
# in the Netlify UI for production deploys.
NETLIFY_EMAILS_PROVIDER=mailgun
NETLIFY_EMAILS_PROVIDER_API_KEY=
NETLIFY_EMAILS_SECRET=
NETLIFY_EMAILS_MAILGUN_DOMAIN=
NETLIFY_EMAILS_MAILGUN_HOST_REGION=non-eu

# Local dev only — absolute path to the emails template directory.
# Not needed in production (the build plugin bundles templates automatically).
NETLIFY_EMAILS_DIRECTORY=/absolute/path/to/idea-board/emails
